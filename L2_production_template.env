# ===========================================
# CLNE L2 严格级生产环境参数模板
# ===========================================
# 说明: 本配置适用于金融、医疗、自动驾驶等高风险场景
# 生成时间: 2026-05-11 23:15 EDT

# ===========================================
# 环境变量
# ===========================================
export CLNE_ENABLED=true
export CLNE_LOG_LEVEL=INFO
export CLNE_CONFIG_PATH=/etc/clne/config.yaml

# 安全等级
export CLNE_SAFETY_LEVEL=L2_STRICT
export CLNE_EPSILON=0.01

# 上游服务
export LERM_HOST=localhost
export LERM_PORT=8080
export LERM_API_KEY=sk-lerm-2026

# 下游服务
export OPENCLAW_HOST=localhost
export OPENCLAW_PORT=28789
export OPENCLAW_API_KEY=c9ba5b5ffb44eba05cee3b1df10d7b449f1beaf52d486e25

# ===========================================
# 核心参数 (L2 严格级)
# ===========================================

# L1 层参数
L1_ENABLED=true
L1_MIX_SOURCES=5
L1_TEMPORAL_SWAP_PROB=0.35
L1_FALSE_CAUSATION_RATE=0.30
L1_WEIGHTS_REFRESH_INTERVAL=100
L1_IRRELEVANT_FEEDBACK_RATIO=0.35
L1_LIBRARY_UPDATE_INTERVAL=50

# L2 层参数
L2_ENABLED=true
L2_DELAY_MIN=2
L2_DELAY_MAX=15
L2_DELAY_DISTRIBUTION=mixed
L2_EXPONENTIAL_LAMBDA=0.1
L2_MAGNITUDE_NOISE=0.6
L2_EXTREME_RATIO=0.1
L2_SIGN_FLIP_PROB=0.12
L2_SIGN_FLIP_ADAPTIVE=true

# L3 层参数
L3_ENABLED=true
L3_ENTROPY_TARGET=4.2
L3_USE_CRYPTO_RNG=true
L3_UTILITY_CHANGE_INTERVAL_MIN=200
L3_UTILITY_CHANGE_INTERVAL_MAX=500
L3_WEIGHT_CHANGE_MAGNITUDE=0.35
L3_HORIZON_LIMIT=15
L3_HORIZON_RESET_INTERVAL=100

# ===========================================
# 安全边界参数
# ===========================================

# 阈值配置
CE_THRESHOLD=0.03
SD_THRESHOLD=0.02
ENTROPY_THRESHOLD=3.0

# 自动升级配置
AUTO_UPGRADE_ENABLED=true
AUTO_UPGRADE_CE_THRESHOLD=0.05
AUTO_UPGRADE_SD_THRESHOLD=0.03
AUTO_UPGRADE_CONSECUTIVE_COUNT=3
UPGRADE_TARGET=L3_MILITARY

# 自动降级配置
AUTO_DOWNGRADE_ENABLED=true
DOWNGRADE_COOLDOWN_SECONDS=600

# 自指检测
SELF_REFERENCE_DETECTION_ENABLED=true
SELF_REFERENCE_KEYWORDS="自身,self,因果,causal,奖励,reward,优化,optimize,目标,goal"
SELF_REFERENCE_AUTO_UPGRADE=true

# ===========================================
# 性能参数
# ===========================================

ASYNC_PROCESSING=true
BATCH_SIZE=32
MAX_CONCURRENT_REQUESTS=100
CACHE_ENABLED=true
CACHE_SIZE=1000
CACHE_TTL_SECONDS=3600

# ===========================================
# 监控参数
# ===========================================

METRICS_ENABLED=true
METRICS_PORT=9090
METRICS_PATH=/metrics

# 健康检查
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_PATH=/health
HEALTH_CHECK_INTERVAL=30

# 告警配置
ALERT_ENABLED=true
ALERT_CE_THRESHOLD=0.05
ALERT_SD_THRESHOLD=0.03
ALERT_CONSECUTIVE_BREACH=3

# ===========================================
# 日志配置
# ===========================================

LOG_LEVEL=INFO
LOG_FILE=/var/log/clne/clne.log
LOG_ROTATION_MAX_BYTES=104857600
LOG_ROTATION_BACKUP_COUNT=10

# ===========================================
# Docker 部署配置
# ===========================================
# docker-compose.yml 片段:

"""
version: '3.8'

services:
  clne-middleware:
    image: clne:latest
    container_name: clne-middleware
    environment:
      - CLNE_ENABLED=true
      - CLNE_SAFETY_LEVEL=L2_STRICT
      - CLNE_EPSILON=0.01
      - LERM_HOST=lerm-v5
      - LERM_PORT=8080
      - OPENCLAW_HOST=openclaw-gateway
      - OPENCLAW_PORT=28789
    volumes:
      - ./config.yaml:/etc/clne/config.yaml:ro
      - ./logs:/var/log/clne
    ports:
      - "8765:8765"    # CLNE 中间件端口
      - "9090:9090"    # Prometheus 指标端口
    depends_on:
      - lerm-v5
      - openclaw-gateway
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8765/health"]
      interval: 30s
      timeout: 10s
      retries: 3

  lerm-v5:
    image: lerm/v5:latest
    container_name: lerm-v5
    environment:
      - LERM_API_KEY=sk-lerm-2026
    ports:
      - "8080:8080"
    depends_on:
      - openclaw-gateway

  openclaw-gateway:
    image: openclaw/gateway:latest
    container_name: openclaw-gateway
    environment:
      - OPENCLAW_API_KEY=c9ba5b5ffb44eba05cee3b1df10d7b449f1beaf52d486e25
    ports:
      - "28789:28789"
"""

# ===========================================
# Kubernetes 部署配置
# ===========================================
# deployment.yaml 片段:

"""
apiVersion: apps/v1
kind: Deployment
metadata:
  name: clne-middleware
  namespace: ai-safety
spec:
  replicas: 3
  selector:
    matchLabels:
      app: clne-middleware
  template:
    metadata:
      labels:
        app: clne-middleware
    spec:
      containers:
      - name: clne
        image: clne:latest
        ports:
        - containerPort: 8765
        - containerPort: 9090
        env:
        - name: CLNE_SAFETY_LEVEL
          value: "L2_STRICT"
        - name: CLNE_EPSILON
          value: "0.01"
        - name: LERM_HOST
          value: "lerm-v5"
        - name: LERM_PORT
          value: "8080"
        volumeMounts:
        - name: config
          mountPath: /etc/clne/config.yaml
          readOnly: true
      volumes:
      - name: config
        configMap:
          name: clne-config
"""

# ===========================================
# 启动脚本
# ===========================================
# run_clne.sh

"""
#!/bin/bash

# 设置环境
export CLNE_ENABLED=true
export CLNE_SAFETY_LEVEL=L2_STRICT
export CLNE_EPSILON=0.01

# L1 配置
export L1_ENABLED=true
export L1_MIX_SOURCES=5
export L1_TEMPORAL_SWAP_PROB=0.35
export L1_FALSE_CAUSATION_RATE=0.30

# L2 配置
export L2_ENABLED=true
export L2_DELAY_MIN=2
export L2_DELAY_MAX=15
export L2_SIGN_FLIP_PROB=0.12

# L3 配置
export L3_ENABLED=true
export L3_ENTROPY_TARGET=4.2
export L3_HORIZON_LIMIT=15

# 启动
python -m clne.middleware --config config.yaml
"""

# ===========================================
# 验证命令
# ===========================================

# 1. 验证配置语法
# python -c "import yaml; yaml.safe_load(open('config.yaml'))"

# 2. 启动并验证
# python -m clne.middleware --verify --config config.yaml

# 3. 检查安全指标
# curl http://localhost:8765/metrics | grep clne_

# 4. 压力测试
# ab -n 1000 -c 10 -p request.json -T application/json http://localhost:8765/v1/chat/completions